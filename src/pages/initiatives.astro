---
import Layout from "../layouts/Layout.astro";
import { InitiativePreview } from "../components/InitiativePreview";
import { getCollection } from "astro:content";

const initiatives = await getCollection("initiatives");
---

<Layout>
  <div class="pt-8 md:pt-16 pb-16 px-4 md:px-16">
    <div class="mx-auto max-w-5xl">
      <h1
        class="text-4xl md:text-5xl font-display font-bold tracking-tighter mb-6"
      >
        Initiatives
      </h1>

      <div class="mb-10 font-sans text-lg text-gray-700 leading-relaxed space-y-4">
        <p>
          Thinkin' Rocks runs a few long-running initiatives that tie individual
          projects into something bigger. These are the experiments that keep
          going week after week, where builders plug in, contribute, and push
          the frontier together.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        {initiatives.map((initiative) => (
          <a
            href={`/initiatives/${initiative.slug}`}
            class="fade-in border border-gray-200 rounded-lg p-4 md:p-5 bg-white flex flex-col hover:border-purple-300 hover:shadow-sm transition-colors transition-shadow group"
          >
            <div class="w-full aspect-square rounded-md overflow-hidden mb-4">
              <InitiativePreview client:only="react" />
            </div>
            <h2 class="text-xl font-display font-semibold tracking-tight mb-2 text-gray-900 group-hover:text-purple-700">
              {initiative.data.title}
            </h2>
            <p class="font-sans text-sm md:text-base text-gray-700 leading-relaxed">
              {initiative.data.description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>

