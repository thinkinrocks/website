---
export const prerender = true;

import Layout from "../../layouts/Layout.astro";
import { HardwareCarousel } from "../../components/HardwareCarousel";
import { getCollection, getEntry } from "astro:content";
import type { HardwareItem } from "../../types/hardware";

export async function getStaticPaths() {
  const hardwareEntries = await getCollection("hardware");
  
  return hardwareEntries.map((entry) => ({
    params: { id: entry.slug },
  }));
}

const { id } = Astro.params;
const entry = await getEntry("hardware", id);
const { Content } = await entry.render();
const item = entry.data as HardwareItem;

const allEntries = await getCollection("hardware");
const allItems = allEntries.map((e) => e.data as HardwareItem);

// Get related hardware items
const relatedItems = item?.related
  ? allItems.filter((hardwareItem) => item.related!.includes(hardwareItem.id))
  : [];

// Function to truncate description by word count
const truncateDescription = (text: string, wordLimit: number = 20) => {
  const words = text.split(' ');
  return words.slice(0, wordLimit).join(' ') + (words.length > wordLimit ? '...' : '');
};

const getStatusBadge = (status: string) => {
  switch (status) {
    case 'coming-soon':
      return 'coming soon';
    case 'maintenance':
      return 'maintenance';
    default:
      return null;
  }
};
---

<Layout>
  <div class="pt-16 md:pt-24 pb-16 px-4 md:px-16">
    <div class="max-w-5xl mx-auto">
      <!-- Back Button -->
      <div class="mb-8">
        <a 
          href="/hardware" 
          class="inline-flex items-center text-purple-600 hover:text-purple-800 font-mono text-sm transition-colors"
        >
          ← Back to Hardware
        </a>
      </div>

      <!-- Hardware Details -->
      <div class="mb-16">
        <!-- Image or Carousel -->
        {item.images && item.images.length > 0 && (
          <HardwareCarousel
            images={item.images}
            name={item.name}
            captions={item.imageCaptions}
            client:load
          />
        )}

        <!-- Details -->
        <div class="space-y-6">
          <div>
            <h1 class="text-4xl md:text-5xl font-display font-bold tracking-tighter mb-4 text-center">
              {item.name}
            </h1>
          </div>

         
          <div>
            <div class="hardware-copy font-sans text-lg text-gray-700 leading-relaxed">
              <Content />
            </div>
          </div>
        </div>
      </div>

      <!-- Related Hardware -->
      {relatedItems.length > 0 && (
        <div class="pt-8">
          <h2 class="text-xl font-display font-bold tracking-tighter mb-4 text-gray-900">
            Related Hardware
          </h2>
          <div class="space-y-3 mb-4">
            {relatedItems.map((relatedItem) => (
              <a
                href={`/hardware/${relatedItem.id}`}
                class="block group"
              >
                <div class="py-1 flex gap-2 md:gap-3 items-center">
                  {relatedItem.images && relatedItem.images.length > 0 ? (
                    <div class="flex-shrink-0">
                      <img
                        src={relatedItem.images[0]}
                        alt={relatedItem.name}
                        class="w-20 h-20 md:w-28 md:h-28 object-contain rounded"
                      />
                    </div>
                  ) : null}
                  <div class="flex-1 min-w-0">
                    <h3 class="text-base md:text-lg font-display mb-1 text-gray-900 group-hover:text-purple-600 transition-colors">
                      {relatedItem.name}
                    </h3>
                    <p class="md:hidden font-sans text-sm text-gray-600 break-words">
                      {truncateDescription(relatedItem.description, 18)}
                    </p>
                    <p class="hidden md:block font-sans text-base text-gray-600 break-words">
                      {truncateDescription(relatedItem.description, 35)}
                    </p>
                  </div>
                </div>
              </a>
            ))}
          </div>
          <div class="text-center">
            <a
              href="/hardware"
              class="inline-flex items-center text-purple-600 hover:text-purple-800 font-mono transition-colors"
            >
              View All Hardware →
            </a>
          </div>
        </div>
      )}
    </div>
  </div>
</Layout>
