---
import Layout from "../../layouts/Layout.astro";
import { getCollection, getEntry } from "astro:content";
import NerdBanner from "../../components/NerdBanner.astro";
import { InitiativePreview } from "../../components/InitiativePreview";

export async function getStaticPaths() {
  const initiatives = await getCollection("initiatives");

  return initiatives.map((initiative) => ({
    params: { slug: initiative.slug },
  }));
}

const { slug } = Astro.params;
const initiative = await getEntry("initiatives", slug);
const { Content } = await initiative.render();
---

<Layout>
  {initiative.data.nerd}

  <div class="pt-16 md:pt-20 pb-16 px-4 md:px-16">
    <div class="mx-auto max-w-3xl">
      <a
        href="/initiatives"
        class="inline-flex items-center mb-6 text-purple-600 hover:text-purple-800 font-mono text-sm transition-colors"
      >
        ← All initiatives
      </a>

      <div class="mb-8">
        <div class="w-full aspect-square max-w-md mx-auto rounded-xl overflow-hidden">
          <InitiativePreview client:only="react" />
        </div>
      </div>

      <h1 class="text-3xl md:text-4xl font-display font-bold tracking-tighter mb-4">
        {initiative.data.title}
      </h1>

      <p class="font-sans text-base md:text-lg text-gray-700 leading-relaxed mb-8">
        {initiative.data.description}
      </p>

      <div class="prose prose-lg max-w-none font-sans text-gray-800">
        <Content />
      </div>
    </div>
  </div>
</Layout>

