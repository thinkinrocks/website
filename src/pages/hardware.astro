---
// Page can be static, hardware loads client-side
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import HardwareSearch from "../components/HardwareSearch.tsx";
import { getCollection } from "astro:content";
import type { HardwareItem } from "../types/hardware";

const hardwareEntries = await getCollection("hardware");
const hardwareItems = hardwareEntries.map((entry) => entry.data) as HardwareItem[];
---

<Layout>
  <div class="pt-8 md:pt-16 pb-16 px-4 md:px-16">
    <div class="max-w-5xl mx-auto w-full">
      <h1 class="text-4xl md:text-5xl font-display font-bold tracking-tighter mb-4">
        Hardware
      </h1>

      <HardwareSearch items={hardwareItems} client:load />
    </div>
  </div>
</Layout>
