---
import Layout from "../layouts/Layout.astro";
import { SpaceCarousel } from "../components/SpaceCarousel";
import partners from "../content/partners.json";
import teamMembers from "../content/team.json";
import { TeamCarousel } from "../components/TeamCarousel";
import { FAQAccordion } from "../components/FAQAccordion";
import faqs from "../content/faq.json";
import spacePhotos from "../content/space-photos.json";
const avatarUrl = (slug: string) => `/images/team/${slug}.jpg`;
const formatMonthYear = (date: string): string => {
  const [year, month] = date.split("-");
  const monthNames = [
    "January",
    "February",
    "March",
    "April",
    "May",
    "June",
    "July",
    "August",
    "September",
    "October",
    "November",
    "December"
  ];

  return `${monthNames[Number(month) - 1]} ${year}`;
};

const carouselImages = spacePhotos.map((photo) => ({
  src: photo.src,
  alt: photo.alt,
  caption: `${photo.description} (${formatMonthYear(photo.date)})`
}));
---

<Layout>
  <div class="pt-8 md:pt-16 pb-16 px-4 md:px-16">
    <div class="mx-auto max-w-5xl">
      <h1
        class="text-4xl md:text-5xl font-display font-bold tracking-tighter mb-6"
      >
        About
      </h1>

      <!-- Main Content -->
      <div class="mb-12 font-sans text-lg text-gray-700 leading-relaxed space-y-4">
        <p>
          Thinkin' Rocks is a prototyping ecosystem. We maintain spaces where people build AI systems, robotics projects, XR applications, embedded devices, and experimental hardware—the kind of stuff that needs actual equipment and other builders around.
        </p>
        
        <p>
          Most technical education teaches theory. Labs are locked behind bureaucracy. Makerspaces have basic equipment. Hardware startups can't afford gear until funding arrives. Researchers work in isolation. Hackathon projects die on Monday. We saw people with skills and drive but nowhere to actually build serious tech.
        </p>
        <!-- Space Photos Carousel -->
        <SpaceCarousel images={carouselImages} client:load />
        <p>
          So we made a place where the default is "yes, try it." Where you can start on Tuesday and have a working prototype by Friday. Where breaking things is learning, and someone in the room has probably solved your exact problem before. Equipment is shared, knowledge transfer is built in, and access comes from showing up and contributing. We also run Nerd Outs—sessions where people share what they're obsessed with, whether it's a circuit they debugged for weeks or an algorithm that won't leave their head.
        </p>
        <p>We're located at <a
            href="https://maps.google.com/?q=Startup+Sauna,+Puumiehenkuja+5,+02150+Espoo,+Finland"
            class="text-purple-600 hover:text-purple-800 transition-colors"
            data-umami-event="location-sus"
            >Startup Sauna</a
          > at Aalto University, second floor.  
          Join our <a
            href="https://t.me/+rxHNt6GA4-o1NWUy"
            class="text-purple-600 hover:text-purple-800 transition-colors"
            target="_blank"
            >Telegram chat</a>, come to a build session, start working on something. That's how it works.
        </p>
      </div>

       

      

      <!-- Partners Section -->
      <div class="mb-6 font-sans text-base md:text-lg text-gray-700 leading-relaxed">
        <h3 id="partners" class="font-mono text-gray-900 mb-3 md:mb-4">Backed by people who get it:</h3>
        <p>
          Industry partners and universities support the lab with equipment, knowledge, and connections to real-world challenges. This lets builders access industry-grade hardware and stay connected to the broader technology ecosystem. Check out our <a
            href="/hardware"
            class="text-purple-600 hover:text-purple-800 transition-colors"
            >hardware page</a
          > to see what's available.
        </p>
      </div>
      
        <div class="mb-16 fade-in">
  <div
    class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4 md:gap-6 mb-8"
  >
    {partners.map((partner) => (
      <div class="bg-gray-50 p-3 md:p-4 lg:p-6 text-center">
        <a
          href={partner.href}
          target="_blank"
          data-umami-event={partner.umamiEvent}
        >
          <div
            class="w-24 h-16 sm:w-32 sm:h-20 md:w-40 md:h-24 mx-auto flex items-center justify-center"
          >
            <img
              src={partner.image}
              alt={partner.alt}
              class="w-full h-full object-contain"
              style="filter: saturate(0);"
            />
          </div>
        </a>
      </div>
    ))}
  </div>
</div>

      <!-- Team Section -->
      <div class="mb-8 font-sans text-lg text-gray-700 leading-relaxed max-w-prose">
        <p class="font-mono text-gray-900">The people who keep this place running:</p>
      </div>

      
<!-- Mobile -->
<div class="md:hidden">
  <TeamCarousel members={teamMembers} client:load />
</div>

<!-- Desktop -->
<div class="hidden md:grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 md:gap-6 mb-8">
  {teamMembers.map((member) => (
    <div class="w-full overflow-hidden rounded-sm border border-gray-200 bg-white">
      <div
        class={`relative aspect-[4/3] bg-gray-100 ${member.imageClass || ""}`}
        style={member.imageStyle || ""}
      >
        <img
          src={avatarUrl(member.slug)}
          alt={member.alt}
          class="absolute inset-0 h-full w-full object-cover object-center"
          loading="lazy"
        />
      </div>

      <div class="bg-[#f3f3f3] px-3 py-2 font-mono text-xs leading-5 text-gray-700">
        <div>
          const name = <span class="text-gray-900">"{member.name}"</span>;
        </div>
        <div>
          const role = <span class="text-gray-900">"{member.role || "team"}"</span>;
        </div>
        <div>
          const tg = <a
            href={member.tgUrl}
            target="_blank"
            data-umami-event={member.umamiEvent}
            class="text-gray-900 hover:underline"
          >"{member.tg}"</a>;
        </div>
      </div>
    </div>
  ))}
</div>
   
  <div class="mb-12">
  <h2
    id="faq"
    class="text-3xl md:text-4xl font-display font-bold tracking-tighter mb-6"
  >
    FAQ
  </h2>

  <FAQAccordion items={faqs} client:load />
</div>
</Layout>
