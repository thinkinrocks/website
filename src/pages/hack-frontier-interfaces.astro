---
import Layout from "../layouts/Layout.astro";
import challenges from "../content/hackathon-challenges.json";

const hackathonName = "Frontier Interfaces Hackathon";
const registrationUrl = "https://thinkinrocks.com";
const prepChatUrl = "https://t.me/+rxHNt6GA4-o1NWUy";
---

<Layout hideNavbar={true}>
	<main class="relative overflow-hidden bg-background">
		<div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top,oklch(0.96_0.03_95),transparent_45%),radial-gradient(circle_at_80%_20%,oklch(0.94_0.03_210),transparent_35%),linear-gradient(to_bottom,oklch(1_0_0)/0.7,oklch(0.98_0_0)/0.9)]"></div>
		
		<!-- Global Background Image -->
		<img 
			id="hero-bg-image"
			src="/images/u8219894999_marble_hand_holding_AR_glasses_glowing_in_pink_from_c8843068-5a1c-4921-8c28-6d66b6ef07f1%20Background%20Removed.png" 
			alt="" 
			class="pointer-events-none fixed left-[70%] top-16 md:top-32 lg:top-40 -translate-x-1/2 z-0 object-contain opacity-100" 
			style="width: 1000px; max-width: 100vw; height: auto; -webkit-mask-image: radial-gradient(ellipse 70% 70% at 50% 40%, black 10%, transparent 80%); mask-image: radial-gradient(ellipse 70% 70% at 50% 40%, black 10%, transparent 80%); will-change: opacity, filter;"
		/>

		<div class="relative z-10 pt-6 px-4 md:pt-8 md:px-16">
			<div class="flex w-full items-center gap-2 md:gap-3">
				<a href="https://varjo.com/" target="_blank" rel="noreferrer" class="flex h-14 flex-1 items-center justify-center px-2 md:px-3">
					<img src="/images/companies-logo/varjo.png" alt="Varjo" class="h-5 md:h-6 w-full object-contain" style="filter: saturate(0);" />
				</a>
				<a href="https://doublepoint.com/" target="_blank" rel="noreferrer" class="flex h-14 flex-1 items-center justify-center px-2 md:px-3">
					<img src="/images/companies-logo/doublepoint.png" alt="Doublepoint" class="h-8 w-full object-contain" style="filter: saturate(0);" />
				</a>
				<a href="https://www.seetruetechnologies.com/" target="_blank" rel="noreferrer" class="flex h-14 flex-1 items-center justify-center px-2 md:px-3">
					<img src="/images/companies-logo/seetrue-technologies.png" alt="SeeTrue Technologies" class="h-10 md:h-14 w-full object-contain scale-110 md:scale-125 transition-transform" style="filter: saturate(0);" />
				</a>
				<a href="https://www.dispelix.com/" target="_blank" rel="noreferrer" class="flex h-14 flex-1 items-center justify-center px-2 md:px-3">
					<img src="/images/companies-logo/dispelix.png" alt="Dispelix" class="h-8 w-full object-contain" style="filter: saturate(0);" />
				</a>
			</div>
			<div class="mt-4 px-3 text-center">
				<span class="text-xs font-mono text-muted-foreground/70 tracking-widest">powered by Thinkin'Rocks*</span>
			</div>
		</div>

		<div class="mt-8 px-4 md:mt-12 md:px-16 relative z-10 w-full flex justify-center">
			<div class="w-full max-w-5xl">
				
				<div class="relative z-10 pt-[25vw] lg:pt-[250px]">


					<h1 class="font-display text-[14vw] leading-[0.85] tracking-tight sm:text-8xl md:text-9xl lg:text-[140px] xl:text-[160px]">
						Frontier<br />
						Interfaces<br />
						Hackathon
					</h1>
					<p class="mt-4 max-w-3xl text-muted-foreground md:text-lg">
						Build new human-computer interfaces with AR, biosignals, and spatial computing.
						<br />
						For engineers, designers, and founders.
					</p>
					
					<div class="mt-8 flex flex-wrap items-center gap-3">
					<a
						href={registrationUrl}
						class="inline-flex w-fit items-center gap-2 whitespace-nowrap bg-fuchsia-50 px-3 py-1.5 text-fuchsia-600 hover:bg-fuchsia-100"
					>
						<span class="font-mono">Register Team</span>
					</a>
					<a
						href={prepChatUrl}
						class="hover:bg-slate-100 w-fit h-fit py-1.5 px-3 text-slate-600 inline-flex items-center gap-2 whitespace-nowrap"
					>
						<span class="font-mono">Join Prep Chat</span>
					</a>
					<a
						id="view-rules-link"
						href="#rules"
						class="hover:bg-slate-100 w-fit h-fit py-1.5 px-3 text-slate-600 inline-flex items-center gap-2 whitespace-nowrap"
					>
						<span class="font-mono">View Rules</span>
					</a> 
				</div>
			</div>

			<div class="mx-auto mt-12 md:mt-16 lg:mt-20 max-w-5xl space-y-14">
				<div class="grid grid-cols-1 md:grid-cols-[0.9fr_1.1fr] items-center gap-14 md:gap-24">
					<div class="order-2 md:order-1">
						<div class="relative" id="timeline-container">
							<div class="absolute bottom-4 left-1 top-4 w-px bg-muted"></div>
							<div class="absolute top-4 left-1 w-px bg-fuchsia-500 transition-all duration-1000" id="timeline-progress-line" style="height: 0px;"></div>
							<ol class="space-y-1.5" id="timeline-events">
								<li class="relative p-3 pl-6 timeline-event" data-date="2026-03-17T12:00:00+02:00">
									<span class="absolute left-0 top-5 h-2.5 w-2.5 rounded-full bg-muted transition-colors duration-500 timeline-dot"></span>
									<p class="inline-flex px-2.5 py-1 text-[11px] font-mono uppercase tracking-[0.14em] text-muted-foreground transition-colors duration-500 timeline-date">March 17 · 12:00</p>
									<p class="mt-1 px-2.5 text-lg font-semibold">Registration Starts</p>
								</li>
								<li class="relative p-3 pl-6 timeline-event" data-date="2026-04-01T12:00:00+03:00">
									<span class="absolute left-0 top-5 h-2.5 w-2.5 rounded-full bg-muted transition-colors duration-500 timeline-dot"></span>
									<p class="inline-flex px-2.5 py-1 text-[11px] font-mono uppercase tracking-[0.14em] text-muted-foreground transition-colors duration-500 timeline-date">April 1 · 12:00</p>
									<p class="mt-1 px-2.5 text-lg font-semibold">Soft Start</p>
									<p class="mt-1 px-2.5 text-sm text-muted-foreground">Ideas, teammate matching, and early lab testing.</p>
								</li>
								<li class="relative p-3 pl-6 timeline-event" data-date="2026-04-17T23:59:00+03:00">
									<span class="absolute left-0 top-5 h-2.5 w-2.5 rounded-full bg-muted transition-colors duration-500 timeline-dot"></span>
									<p class="inline-flex px-2.5 py-1 text-[11px] font-mono uppercase tracking-[0.14em] text-muted-foreground transition-colors duration-500 timeline-date">April 17 · 23:59</p>
									<p class="mt-1 px-2.5 text-lg font-semibold">Registration Deadline</p>
								</li>
								<li class="relative p-3 pl-6 timeline-event" data-date="2026-04-24T18:00:00+03:00">
									<span class="absolute left-0 top-5 h-2.5 w-2.5 rounded-full bg-muted transition-colors duration-500 timeline-dot"></span>
									<p class="inline-flex px-2.5 py-1 text-[11px] font-mono uppercase tracking-[0.14em] text-muted-foreground transition-colors duration-500 timeline-date">April 24 · 18:00</p>
									<p class="mt-1 px-2.5 text-lg font-semibold">Forum Kickoff</p>
									<p class="mt-1 px-2.5 text-sm text-muted-foreground">Partner demos, founder advice, and team alignment.</p>
								</li>
								<li class="relative p-3 pl-6 timeline-event" data-date="2026-04-24T20:00:00+03:00">
									<span class="absolute left-0 top-5 h-2.5 w-2.5 rounded-full bg-muted transition-colors duration-500 timeline-dot"></span>
									<p class="inline-flex px-2.5 py-1 text-[11px] font-mono uppercase tracking-[0.14em] text-muted-foreground transition-colors duration-500 timeline-date">April 24-26</p>
									<p class="mt-1 px-2.5 text-lg font-semibold">Main Hackathon</p>
									<p class="mt-1 px-2.5 text-sm text-muted-foreground">Build and iterate into a working demo.</p>
								</li>
								<li class="relative p-3 pl-6 timeline-event" data-date="2026-04-26T15:00:00+03:00">
									<span class="absolute left-0 top-5 h-2.5 w-2.5 rounded-full bg-muted transition-colors duration-500 timeline-dot"></span>
									<p class="inline-flex px-2.5 py-1 text-[11px] font-mono uppercase tracking-[0.14em] text-muted-foreground transition-colors duration-500 timeline-date">April 26 · 15:00</p>
									<p class="mt-1 px-2.5 text-lg font-semibold">Final Showcase</p>
									<p class="mt-1 px-2.5 text-sm text-muted-foreground">Stage demo and judging.</p>
								</li>
							</ol>
						</div>
					</div>
					<div class="order-1 md:order-2">
						<p class="text-muted-foreground">
							Join Frontier Interfaces Hackathon to explore new ways to interact with machines and build better interfaces with brain waves,
					biosensing, or augmented reality. The event is open to engineers, designers, and business students, with an emphasis on
					creative technology combinations that can find a practical use case in the real world. The hackathon is organized by Thinkin' Rocks, which hosts an applied engineering lab at Startup Sauna. Challenges will
							be revealed at the soft start of the hackathon. Only one person should register for each team. If you need to make
							changes to your registration, contact the organizers on Telegram at @foxivil. Teams will be called before the event
							to confirm registration.
						</p>
						<div class="mt-4 space-y-1 text-sm text-muted-foreground md:text-base">
							<p><span class="font-semibold text-foreground">Dates:</span> April 1-April 26</p>
							<p><span class="font-semibold text-foreground">Location:</span> Thinkin' Rocks Lab, Startup Sauna</p>
						</div>
						<p class="mt-4 text-muted-foreground">
							Website: <a class="underline underline-offset-2" href="https://thinkinrocks.com">thinkinrocks.com</a>
						</p>
					</div>

					
				</div>

				<div id="available-tools" class="pt-8 md:pt-12">
					<h2 class="font-display text-2xl tracking-tight md:text-3xl">Available Tools</h2>
					<p class="mt-4 max-w-3xl text-muted-foreground">
						Participants will have access to a variety of hardware interfaces and sensors at the lab, including:
					</p>
					<ul class="mt-4 list-disc space-y-2 pl-6 text-sm text-muted-foreground">
						<li><strong class="font-semibold text-foreground">XR & Optics:</strong> Varjo headsets, Dispelix displays</li>
						<li><strong class="font-semibold text-foreground">Biosignals:</strong> OpenBCI headsets, Emotibit sensors</li>
						<li><strong class="font-semibold text-foreground">Tracking & Input:</strong> SeeTrue eye trackers, Doublepoint kits, and motion trackers</li>
					</ul>
				</div>

				<div id="challenges" class="pt-8 md:pt-12">
					<h2 class="font-display text-2xl tracking-tight md:text-3xl">Challenges</h2>
					<p id="challenge-reveal-text" class="mt-4 max-w-3xl text-muted-foreground">
						Challenge tracks will be revealed at the soft start on April 1, with themes spanning AR, biosignals, and new interaction design.
					</p>

					<div class="mt-8 mb-8 flex justify-center gap-3 md:gap-4" id="hackathon-countdown">
						<div class="flex min-w-[6rem] flex-col items-center justify-center  bg-muted/40 p-4 md:min-w-[7rem]">
							<span id="countdown-days" class="font-display text-4xl font-semibold text-foreground md:text-5xl">00</span>
							<span class="mt-2 text-xs font-mono uppercase tracking-widest text-muted-foreground">Days</span>
						</div>
						<div class="flex min-w-[6rem] flex-col items-center justify-center  bg-muted/40 p-4 md:min-w-[7rem]">
							<span id="countdown-hours" class="font-display text-4xl font-semibold text-foreground md:text-5xl">00</span>
							<span class="mt-2 text-xs font-mono uppercase tracking-widest text-muted-foreground">Hours</span>
						</div>
						<div class="flex min-w-[6rem] flex-col items-center justify-center bg-muted/40 p-4 md:min-w-[7rem]">
							<span id="countdown-minutes" class="font-display text-4xl font-semibold text-foreground md:text-5xl">00</span>
							<span class="mt-2 text-xs font-mono uppercase tracking-widest text-muted-foreground">Mins</span>
						</div>
						<div class="flex min-w-[6rem] flex-col items-center justify-center  bg-muted/40 p-4 md:min-w-[7rem]">
							<span id="countdown-seconds" class="font-display text-4xl font-semibold text-foreground md:text-5xl">00</span>
							<span class="mt-2 text-xs font-mono uppercase tracking-widest text-muted-foreground">Secs</span>
						</div>
					</div>

					<script>
						function initHeroScroll() {
							const bgImage = document.getElementById("hero-bg-image");
							if (!bgImage) return;

							const handleScroll = () => {
								const scrollY = window.scrollY;
								// Start fading from 0px scroll, fully muted by 600px scroll
								const progress = Math.min(1, Math.max(0, scrollY / 600));
								
								// Reduce opacity (from 1 down to 0.3)
								const opacity = 1 - (progress * 0.7);
								
								// Reduce saturation (from 1 down to 0)
								const saturate = 1 - progress;

								bgImage.style.opacity = opacity.toString();
								bgImage.style.filter = `saturate(${saturate})`;
							};

							window.addEventListener("scroll", handleScroll, { passive: true });
							// Run once immediately on load
							handleScroll();
						}

						function initTimeline() {
							const now = Date.now();
							const events = document.querySelectorAll(".timeline-event");
							const progressLine = document.getElementById("timeline-progress-line");
							if (!progressLine || events.length === 0) return;
							
							let lastPassedTop = 0;
							let lastDate = 0;
							let nextTop = 0;
							let nextDate = 0;

							events.forEach((el) => {
								const dateAttr = el.getAttribute("data-date");
								if (!dateAttr) return;
								
								const timestamp = new Date(dateAttr).getTime();
								const dot = el.querySelector(".timeline-dot");
								const dateText = el.querySelector(".timeline-date");
								const dotTop = el.offsetTop + 20; // 20px because of top-5

								if (now >= timestamp) {
									if (dot) {
										dot.classList.remove("bg-muted");
										dot.classList.add("bg-fuchsia-500");
									}
									if (dateText) {
										dateText.classList.remove("text-muted-foreground");
										dateText.classList.add("text-fuchsia-500");
									}
									lastPassedTop = dotTop;
									lastDate = timestamp;
								} else {
									if (nextTop === 0) {
										nextTop = dotTop;
										nextDate = timestamp;
									}
								}
							});

							let finalHeight = 0;
							if (lastPassedTop === 0) {
								finalHeight = 0;
							} else if (nextTop === 0) {
								finalHeight = lastPassedTop;
							} else {
								const timeDiff = nextDate - lastDate;
								const timePassed = now - lastDate;
								const ratio = Math.max(0, Math.min(1, timePassed / timeDiff));
								finalHeight = lastPassedTop + (nextTop - lastPassedTop) * ratio;
							}

							progressLine.style.height = `${finalHeight}px`;
						}

						function initTimer() {
							// April 1, 2026, 17:00 EEST (Finnish time: UTC+3 during DST)
							const target = new Date("2026-04-01T17:00:00+03:00").getTime();
							
							function update() {
								const dEl = document.getElementById("countdown-days");
								const hEl = document.getElementById("countdown-hours");
								const mEl = document.getElementById("countdown-minutes");
								const sEl = document.getElementById("countdown-seconds");
								const countdownContainer = document.getElementById("hackathon-countdown");
								const revealText = document.getElementById("challenge-reveal-text");
								const tracksContainer = document.getElementById("tracks-container");
								
								if (!dEl || !hEl || !mEl || !sEl) return;
								
								const diff = target - Date.now();
								
								if (diff <= 0) {
									if (countdownContainer) countdownContainer.style.display = "none";
									if (revealText) revealText.style.display = "none";
									if (tracksContainer) tracksContainer.style.display = "block";
									return;
								}
								
								const days = Math.floor(diff / (1000 * 60 * 60 * 24));
								const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
								const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
								const secs = Math.floor((diff % (1000 * 60)) / 1000);
								
								dEl.innerText = String(days).padStart(2, '0');
								hEl.innerText = String(hours).padStart(2, '0');
								mEl.innerText = String(mins).padStart(2, '0');
								sEl.innerText = String(secs).padStart(2, '0');
							}
							
							update();
							setInterval(update, 1000);
						}
						
						// Run on initial load and handle Astro view transitions if enabled
						document.addEventListener("DOMContentLoaded", () => {
							initTimer();
							initTimeline();
							initHeroScroll();
						});
						document.addEventListener("astro:page-load", () => {
							initTimer();
							initTimeline();
							initHeroScroll();
						});
						initTimer();
						initTimeline();
						initHeroScroll();
					</script>

					<div id="tracks-container" style="display: none;">
						<div class="mt-6 grid gap-4 md:grid-cols-3">
							{challenges.map((challenge) => (
								<div class="rounded-xl bg-muted/50 p-4">
									<p class="text-xs font-mono uppercase tracking-[0.14em] text-muted-foreground">{challenge.track}</p>
									<p class="mt-2 font-semibold">{challenge.title}</p>
									<p class="mt-1 text-sm text-muted-foreground">{challenge.description}</p>
								</div>
							))}
						</div>
					</div>
				</div>

				

				<div id="rules">
					<h2 class="font-display text-2xl tracking-tight md:text-3xl">Rules</h2>
					<ul class="mt-4 list-disc space-y-2 pl-6 text-sm text-muted-foreground">
						<li>Teams must have 3-5 people.</li>
						<li>You can register alone and find teammates at our space or at the beginning of the hackathon.</li>
						<li>You can use any hardware and compute power to prepare your demo.</li>
						<li>We strongly recommend experimenting with OpenBCI headsets, Emotibit, eye tracker, and motion trackers in our lab before the hackathon.</li>
						<li>Show meaningful progress during the hackathon for your selected track.</li>
						<li>If you use any pre-existing work (including open source libraries) that gives you an advantage, you must disclose it.</li>
		
						<li>Use biometric or physiological data responsibly and with consent.</li>
					</ul>
				</div>
                
				<!-- Spacer for bottom padding -->
				<div class="h-32 md:h-64"></div>
			</div>
		</div>
	</main>
</Layout>
