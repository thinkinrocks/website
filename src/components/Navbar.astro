---
import { FaDiscord, FaLinkedin, FaTelegram, FaInstagram } from "react-icons/fa";
import MobileNav from "./MobileNav.tsx";

// Get current page from Astro.url
const currentPath = Astro.url.pathname;

import socials from "../content/socials.json";

const iconMap = {
  discord: FaDiscord,
  linkedin: FaLinkedin,
  telegram: FaTelegram,
  instagram: FaInstagram,
} as const;
---

<!-- Navigation: same horizontal padding and max-width as page content -->
<div id="navbar" class="fixed top-0 left-0 right-0 z-40 transition-all duration-300">
  <!-- Desktop Navigation -->
  <div class="hidden md:block w-full px-4 md:px-16">
    <div class="max-w-5xl mx-auto w-full">
      <div class="flex items-center justify-between h-12 w-full">
        <!-- Navigation Links -->
        <div class="flex items-center space-x-2">
          <a href="/" id="tr-link-desktop" class={`font-mono nav-item hover:text-purple-600 ${(currentPath === '/' || currentPath === '') ? 'text-purple-600 font-medium' : 'text-gray-700'}`}>TR*</a>
          <span class="text-gray-700">|</span>
          <a href="/about" class={`font-mono nav-item hover:text-purple-600 ${currentPath.startsWith('/about') ? 'text-purple-600 font-medium' : 'text-gray-700'}`}>about</a>
          <span class="text-gray-700">|</span>
          <a href="/events" class={`font-mono nav-item hover:text-purple-600 ${currentPath.startsWith('/events') ? 'text-purple-600 font-medium' : 'text-gray-700'}`}>events</a>
          <span class="text-gray-700">|</span>
          <a href="/log" class={`font-mono nav-item hover:text-purple-600 ${currentPath.startsWith('/log') ? 'text-purple-600 font-medium' : 'text-gray-700'}`}>log</a>
          <span class="text-gray-700">|</span>
          <a href="/code-of-conduct" class={`font-mono nav-item hover:text-purple-600 ${currentPath.startsWith('/code-of-conduct') ? 'text-purple-600 font-medium' : 'text-gray-700'}`}>conduct</a>
        </div>
        
        <!-- Social Media Icons -->
        <div class="flex items-center space-x-3">
  {socials.map((item) => {
    const Icon = iconMap[item.icon as keyof typeof iconMap];

    return (
      <a
        data-umami-event={item.umamiEvent}
        href={item.href}
        class="text-purple-800 hover:text-purple-950 transition-colors"
        aria-label={item.ariaLabel}
        target="_blank"
        rel="noreferrer"
      >
        <Icon className="w-4 h-4" />
      </a>
    );
  })}
</div>
      </div>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div class="md:hidden px-4 flex items-center justify-between h-14">
    <a href="/" class={`flex items-center h-5 font-mono text-sm font-medium transition-colors duration-200 ${(currentPath === '/' || currentPath === '') ? 'text-purple-600' : 'text-gray-900 hover:text-purple-600'}`}>
      Thinkin' Rocks*
    </a>
    <MobileNav currentPath={currentPath} client:load />
  </div>
</div>

<style>
  /* Solid white background on scroll */
  #navbar.navbar-scrolled {
    background-color: rgb(255, 255, 255);
  }
</style>

<script>
  // Handle TR button clicks to reload homepage animations
  function setupTRLinks() {
    const trLinkDesktop = document.getElementById('tr-link-desktop');

    function handleTRClick(e: Event) {
      const currentPath = window.location.pathname;
      // If we're already on the homepage, force reload to trigger animations
      if (currentPath === '/' || currentPath === '') {
        e.preventDefault();
        window.location.reload();
      }
      // Otherwise, allow normal navigation
    }

    if (trLinkDesktop) {
      trLinkDesktop.addEventListener('click', handleTRClick);
    }
  }

  // Handle navbar background on scroll
  function setupNavbarScroll() {
    const navbar = document.getElementById('navbar');
    if (!navbar) return;

    function handleScroll() {
      if (!navbar) return; // Additional null check for type safety
      
      // Find the title element (h1)
      const title = document.querySelector('h1');
      if (!title) {
        // Fallback to simple scroll check if title not found
        if (window.scrollY > 0) {
          navbar.classList.add('navbar-scrolled');
        } else {
          navbar.classList.remove('navbar-scrolled');
        }
        return;
      }

      // Get the position of the title
      const titleRect = title.getBoundingClientRect();
      const navbarHeight = navbar.offsetHeight;

      // Add class when navbar reaches the title
      if (titleRect.top <= navbarHeight) {
        navbar.classList.add('navbar-scrolled');
      } else {
        navbar.classList.remove('navbar-scrolled');
      }
    }

    window.addEventListener('scroll', handleScroll);
    // Set initial state
    handleScroll();
  }

  // Run on page load
  setupTRLinks();
  setupNavbarScroll();

  // Re-run on Astro page transitions (if View Transitions are enabled)
  document.addEventListener('astro:page-load', () => {
    setupTRLinks();
    setupNavbarScroll();
  });
</script>

<!-- Spacer to account for fixed navbar -->
<div class="h-12"></div>
