---
export interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div
  id={id}
  class="fixed inset-x-0 top-16 md:top-20 z-40 pointer-events-none opacity-0 -translate-y-2 transition-all duration-300 ease-out"
>
  <div class="mx-auto flex justify-center px-4 md:px-6">
    <div class="w-full max-w-sm md:max-w-md rounded-2xl bg-white/90 backdrop-blur-xl border border-purple-300 shadow-[0_18px_45px_rgba(88,28,135,0.35)] px-4 md:px-5 py-3.5 flex items-center gap-3 text-xs md:text-sm font-sans text-gray-900 pointer-events-auto">
      <div class="flex-1">
        <p class="text-center md:text-left leading-snug">
          psst... you seem interested in cool tech. come hang out with us on{" "}
          <a
            href="https://t.me/thinkinrocks"
            target="_blank"
            rel="noreferrer"
            class="underline decoration-dotted underline-offset-2 text-purple-700 hover:text-purple-900"
          >
            Telegram
          </a>
          .
        </p>
      </div>
      <button
        type="button"
        aria-label="Close"
        data-nerd-close
        class="flex-shrink-0 inline-flex h-6 w-6 items-center justify-center rounded-full border border-gray-300 bg-white/70 text-gray-500 hover:text-gray-800 hover:bg-white transition-colors text-xs"
      >
        ✕
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const script = document.currentScript;
    if (!script) return;

    // The banner wrapper is the previous sibling of this inline script
    const el = script.previousElementSibling;
    if (!el) return;

    // Show immediately for now (as a push-style notification)
    setTimeout(() => {
      el.classList.remove("opacity-0", "-translate-y-2");
      el.classList.add("opacity-100", "translate-y-0");
    }, 0);

    // Close button
    const closeBtn = el.querySelector("[data-nerd-close]");
    if (closeBtn) {
      closeBtn.addEventListener("click", () => {
        el.classList.add("opacity-0", "-translate-y-2");
        el.classList.remove("opacity-100", "translate-y-0");
      });
    }
  })();
</script>

